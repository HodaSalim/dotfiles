#!/usr/bin/env sh

spacebar -m config position                     "top"
spacebar -m config height                       "25"
spacebar -m config spacing_left                 "10"
spacebar -m config spacing_right                "20"

spacebar -m config text_font                    "MesloLGL Nerd Font:Regular:12.0"
spacebar -m config icon_font                    "Font Awesome 5 Free:Solid:12.0"

spacebar -m config background_color             0xff282828 
spacebar -m config foreground_color             0xffebdbb2
spacebar -m config space_icon_color             0xfffe8019
spacebar -m config power_icon_color             0xfffabd2f
spacebar -m config battery_icon_color           0xffb8bb26
spacebar -m config dnd_icon_color               0xffFF5C57
spacebar -m config clock_icon_color             0xfffb4934

spacebar -m config space_icon_strip             I II III IV V VI VII VIII IV X
spacebar -m config spaces_for_all_displays      "on"
spacebar -m config display_separator            "on"
spacebar -m config display_separator_icon       "•"

spacebar -m config padding_left                 "25"
spacebar -m config padding_right                "25"

spacebar -m config power_icon_strip             "" ""
spacebar -m config space_icon                   ""
spacebar -m config clock_icon                   ""
spacebar -m config dnd_icon                     ""
spacebar -m config clock_format                 "%a %m/%d %H:%M %p"

spacebar -m config title                        "off"
spacebar -m config center_shell                 "off"
